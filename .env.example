# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/scholar_db

# API Security
API_KEY=replace_with_a_secure_random_key

# JWT Configuration
JWT_SECRET=replace_with_a_secure_jwt_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Database bootstrap (set false in shared/prod environments)
DB_AUTO_CREATE=true

# CORS Configuration (comma-separated origins, use * for all)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
